{
  "info": {
    "_postman_id": "0a0c0f91-8f80-45a1-9a0e-user-management",
    "name": "User Management Service - Secured APIs",
    "description": "Import this collection to test Keycloak token security, admin-only UserType APIs, and token-required user APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:9090" },
    { "key": "keycloakUrl", "value": "http://localhost:8081" },
    { "key": "realm", "value": "user-management" },
    { "key": "clientId", "value": "user-management-client" },
    { "key": "clientSecret", "value": "" },
    { "key": "adminUsername", "value": "admin-user" },
    { "key": "adminPassword", "value": "admin123" },
    { "key": "normalUsername", "value": "normal-user" },
    { "key": "normalPassword", "value": "user123" },
    { "key": "adminAccessToken", "value": "" },
    { "key": "normalAccessToken", "value": "" },
    { "key": "userTypeId", "value": "00000000-0000-0000-0000-000000000000" },
    { "key": "userId", "value": "00000000-0000-0000-0000-000000000000" },
    { "key": "roleName", "value": "PORTAL_ADMIN" }
  ],
  "item": [
    {
      "name": "00 - Setup Notes",
      "item": [
        {
          "name": "Read Me",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{keycloakUrl}}",
              "host": ["{{keycloakUrl}}"]
            },
            "description": "Before testing: create realm user-management, create client user-management-client with Direct access grants enabled, create realm role admin, create admin-user with admin role, and create normal-user without admin role. If your client is confidential, enable the client_secret field in token requests and set clientSecret."
          }
        }
      ]
    },
    {
      "name": "01 - Auth",
      "item": [
        {
          "name": "Get Admin Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('token request succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('adminAccessToken', json.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password", "type": "text" },
                { "key": "client_id", "value": "{{clientId}}", "type": "text" },
                { "key": "client_secret", "value": "{{clientSecret}}", "type": "text", "disabled": true },
                { "key": "username", "value": "{{adminUsername}}", "type": "text" },
                { "key": "password", "value": "{{adminPassword}}", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token",
              "host": ["{{keycloakUrl}}"],
              "path": ["realms", "{{realm}}", "protocol", "openid-connect", "token"]
            },
            "description": "Use a Keycloak user that has the admin realm role. Saves token to adminAccessToken."
          }
        },
        {
          "name": "Get Normal User Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('token request succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('normalAccessToken', json.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password", "type": "text" },
                { "key": "client_id", "value": "{{clientId}}", "type": "text" },
                { "key": "client_secret", "value": "{{clientSecret}}", "type": "text", "disabled": true },
                { "key": "username", "value": "{{normalUsername}}", "type": "text" },
                { "key": "password", "value": "{{normalPassword}}", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token",
              "host": ["{{keycloakUrl}}"],
              "path": ["realms", "{{realm}}", "protocol", "openid-connect", "token"]
            },
            "description": "Use a Keycloak user without the admin realm role. Saves token to normalAccessToken."
          }
        }
      ]
    },
    {
      "name": "02 - Security Tests",
      "item": [
        {
          "name": "No Token - API Returns 401",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('missing token is rejected', function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users"]
            }
          }
        },
        {
          "name": "Normal Token - UserType Returns 403",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('non-admin token is forbidden', function () {",
                  "  pm.response.to.have.status(403);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{normalAccessToken}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/userTypes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "userTypes"]
            }
          }
        },
        {
          "name": "Admin Token - UserType Returns 200",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('admin token is allowed', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{adminAccessToken}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/userTypes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "userTypes"]
            }
          }
        }
      ]
    },
    {
      "name": "03 - User Types - Admin Only",
      "auth": {
        "type": "bearer",
        "bearer": [
          { "key": "token", "value": "{{adminAccessToken}}", "type": "string" }
        ]
      },
      "item": [
        {
          "name": "List Keycloak Roles",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/userTypes/roles",
              "host": ["{{baseUrl}}"],
              "path": ["api", "userTypes", "roles"]
            }
          }
        },
        {
          "name": "Create User Type",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.id) pm.collectionVariables.set('userTypeId', json.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"employee-{{$timestamp}}\",\n  \"description\": \"Employee user type\",\n  \"roleName\": \"{{roleName}}\",\n  \"status\": \"ACTIVE\",\n  \"fields\": [\n    {\n      \"fieldName\": \"department\",\n      \"displayName\": \"Department\",\n      \"dataType\": \"string\",\n      \"required\": true,\n      \"validation\": {}\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/userTypes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "userTypes"]
            }
          }
        },
        {
          "name": "Get All User Types",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/userTypes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "userTypes"]
            }
          }
        },
        {
          "name": "Get User Type By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/userTypes/{{userTypeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "userTypes", "{{userTypeId}}"]
            }
          }
        },
        {
          "name": "Update User Type",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"employee-updated-{{$timestamp}}\",\n  \"description\": \"Updated employee user type\",\n  \"roleName\": \"{{roleName}}\",\n  \"status\": \"ACTIVE\",\n  \"fields\": [\n    {\n      \"fieldName\": \"department\",\n      \"displayName\": \"Department\",\n      \"dataType\": \"string\",\n      \"required\": true,\n      \"validation\": {}\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/userTypes/{{userTypeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "userTypes", "{{userTypeId}}"]
            }
          }
        },
        {
          "name": "Deactivate User Type",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/userTypes/{{userTypeId}}/deactivate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "userTypes", "{{userTypeId}}", "deactivate"]
            }
          }
        },
        {
          "name": "Delete User Type",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/userTypes/{{userTypeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "userTypes", "{{userTypeId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "04 - Admin Users - Token Required",
      "auth": {
        "type": "bearer",
        "bearer": [
          { "key": "token", "value": "{{adminAccessToken}}", "type": "string" }
        ]
      },
      "item": [
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.id) pm.collectionVariables.set('userId', json.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john.doe.{{$timestamp}}\",\n  \"email\": \"john.doe.{{$timestamp}}@example.com\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"phoneNumber\": \"+201000000000\",\n  \"userTypeId\": \"{{userTypeId}}\",\n  \"enabled\": true,\n  \"attributes\": {\n    \"department\": \"Engineering\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users"]
            }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users"]
            }
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users", "{{userId}}"]
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john.doe.updated\",\n  \"email\": \"john.updated@example.com\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"phoneNumber\": \"+201000000001\",\n  \"userTypeId\": \"{{userTypeId}}\",\n  \"enabled\": true,\n  \"attributes\": {\n    \"department\": \"Product\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users", "{{userId}}"]
            }
          }
        },
        {
          "name": "Activate User",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/users/{{userId}}/activate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users", "{{userId}}", "activate"]
            }
          }
        },
        {
          "name": "Deactivate User",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/users/{{userId}}/deactivate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users", "{{userId}}", "deactivate"]
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users", "{{userId}}"]
            }
          }
        }
      ]
    }
  ]
}
